# ============================================================
# POSTGRESQL — cadena de conexión de Neon / Supabase / Railway
# La encontrás en tu panel cloud → "Connection string"
# ============================================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ============================================================
# SEGURIDAD JWT
# ============================================================
# Generá una clave en: https://generate-secret.vercel.app/64
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_y_aleatoria
JWT_EXPIRES_IN=8h

# ============================================================
# CREDENCIALES DE ACCESO A LA APP
# ============================================================
ADMIN_USERNAME=admin

# Hash bcrypt de la contraseña. Para generar uno:
#   cd web-app && npm install
#   node -e "const b=require('bcryptjs');b.hash('TU_CONTRASEÑA',12).then(h=>console.log(h))"
# Contraseña por defecto: Mix2Win2026! — CAMBIALA antes de publicar
# IMPORTANTE: escapá cada $ con \$ al pegar el hash (ej: \$2a\$12\$...)
ADMIN_PASSWORD_HASH=\$2a\$12\$LQv3c1yqBWVHxkd0LHAkCOYz6TIxJFkwRl5V5c0JqpIiP5C8TkMZy
